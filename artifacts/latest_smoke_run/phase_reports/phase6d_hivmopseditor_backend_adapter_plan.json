{
  "schema_version": "hivm_phase6d_hivmopseditor_backend_adapter_plan_v1",
  "phase": "Phase-6D",
  "build_location": "<vTriton>/tools/hivm-operation-backend/",
  "requires": [
    "vTriton source tree",
    "TRITONSIM_HAS_BISHENGIR_HIVM enabled if HIVM dialect is external",
